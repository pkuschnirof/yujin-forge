{
  "name": "@yujin/forge-cli",
  "version": "0.1.0",
  "description": "Yujin Forge -- CLI for the commercial NAC-3 React development framework.",
  "license": "Apache-2.0",
  "bin": {
    "yf": "./dist/bin/yf.js"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/bin/yf.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "yf": "tsx src/bin/yf.ts"
  },
  "dependencies": {
    "commander": "12.1.0",
    "kleur": "4.1.5",
    "prompts": "2.4.2",
    "typescript": "5.7.2"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/prompts": "2.4.9",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=18.17"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "nac",
    "nac-3",
    "react",
    "framework",
    "claude-code",
    "yujin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pkuschnirof/yujin-forge.git"
  }
}
